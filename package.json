{
  "name": "@veridia/node-sdk",
  "version": "1.0.20",
  "description": "",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "npm pkg get version | xargs -I {} sh -c \"sed -i.bak -e 's/__SDK_VERSION__/{}/g' src/version.ts && rm -f src/version.ts.bak\" && npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "clean": "rm -rf dist",
    "test": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "prepare": "husky install"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@smithy/signature-v4": "^5.3.5",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^4.0.6",
    "eslint": "^9.38.0",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^8.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/veridia-io/veridia-node-sdk.git"
  },
  "license": "MIT"
}
